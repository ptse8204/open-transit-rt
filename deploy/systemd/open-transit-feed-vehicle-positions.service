[Unit]
Description=Open Transit RT — feed-vehicle-positions
Documentation=https://github.com/YOUR_ORG/open-transit-rt
After=network.target postgresql-15.service
Wants=postgresql-15.service

[Service]
Type=simple
User={{OCI_APP_USER}}
WorkingDirectory={{OCI_REMOTE_DIR}}/app
EnvironmentFile={{OCI_REMOTE_DIR}}/env
Environment="PORT=8083"
ExecStart={{OCI_REMOTE_DIR}}/bin/feed-vehicle-positions
Restart=on-failure
RestartSec=5s

NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ReadWritePaths={{OCI_REMOTE_DIR}}

[Install]
WantedBy=multi-user.target
