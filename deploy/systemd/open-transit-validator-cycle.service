[Unit]
Description=Open Transit RT pilot validator cycle
Documentation=https://github.com/YOUR_ORG/open-transit-rt
After=network.target open-transit-agency-config.service
Wants=open-transit-agency-config.service

[Service]
Type=oneshot
User={{OCI_APP_USER}}
Group={{OCI_APP_USER}}
WorkingDirectory={{OCI_REMOTE_DIR}}/app
EnvironmentFile={{OCI_REMOTE_DIR}}/ops/pilot-ops.env
ExecStart={{OCI_REMOTE_DIR}}/app/scripts/pilot-ops.sh validator-cycle
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ReadWritePaths={{OCI_REMOTE_DIR}}

