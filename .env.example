# Open Transit RT local development defaults.
# Copy to .env and adjust values for your environment.

DATABASE_URL=postgres://postgres:postgres@localhost:55432/open_transit_rt?sslmode=disable
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:55432/open_transit_rt_test?sslmode=disable
MIGRATIONS_DIR=db/migrations

AGENCY_ID=demo-agency
PUBLIC_BASE_URL=http://localhost:8080
FEED_BASE_URL=http://localhost:8083/public
VEHICLE_POSITIONS_FEED_URL=
SCHEDULE_FEED_URL=http://localhost:8081/public/gtfs/schedule.zip
TECHNICAL_CONTACT_EMAIL=dev@example.com
FEED_LICENSE_NAME=CC BY 4.0
FEED_LICENSE_URL=https://creativecommons.org/licenses/by/4.0/
PUBLICATION_ENVIRONMENT=dev

AGENCY_CONFIG_PORT=8081
TELEMETRY_INGEST_PORT=8082
FEED_VEHICLE_POSITIONS_PORT=8083
TRIP_UPDATES_PORT=8084
ALERTS_PORT=8085
ADMIN_PORT=8086
PORT=8080

AUTH_MODE=disabled
JWT_SECRET=dev-only-change-me
DEVICE_TOKEN_SALT=dev-only-device-token-salt

METRICS_ENABLED=true
METRICS_PORT=9090
LOG_LEVEL=info

MATCH_CONFIDENCE_THRESHOLD=0.75
MATCH_CONTINUITY_WINDOW_SECONDS=300
STALE_TELEMETRY_TTL_SECONDS=90
SUPPRESS_STALE_VEHICLE_AFTER_SECONDS=300
VEHICLE_POSITIONS_MAX_VEHICLES=2000
VEHICLE_POSITIONS_TRIP_CONFIDENCE_THRESHOLD=0.65
TRIP_UPDATES_ADAPTER=deterministic
TRIP_UPDATES_MAX_VEHICLES=2000
TRIP_UPDATES_STALE_TELEMETRY_TTL_SECONDS=90
TRIP_UPDATES_ASSIGNMENT_CONFIDENCE_THRESHOLD=0.65
TRIP_UPDATES_MAX_SCHEDULE_DEVIATION_SECONDS=2700
TRIP_UPDATES_DUPLICATE_CONFIDENCE_GAP=0.05

VALIDATOR_STRICTNESS=warn
GTFS_VALIDATOR_PATH=
GTFS_RT_VALIDATOR_COMMAND=
GTFS_RT_VALIDATOR_PATH=
SEED_FIXTURE_DIR=testdata
